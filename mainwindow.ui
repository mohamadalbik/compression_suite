QMainWindow {
 background-color: #ffffff;
 color: #f5f5f5;
 font-family: Segoe UI;
 font-size: 10pt;
}

QFrame#topBar {
 background-color: #111656;
 border-bottom: 1px solid #e0e0e0;
 padding: 10px;
 font-size: 14pt;
 font-weight: bold;
 qproperty-alignment: AlignCenter;
}
QLabel#labelTitle {
    color: #f5f5f5;
    font-size: 24pt;
    font-weight: bold;
}

QPushButton {
 background-color: #111656;
 color: white;
 border: none;
 padding: 6px 12px;
 border-radius: 4px;
}

QPushButton:hover {
 background-color: #1a252f;
}

QPushButton#btnStart {
 background-color: #111656;
}

QPushButton#btnStart:hover {
 background-color: #005fa3;
}

QTableWidget {
 background-color: #ffffff;
 border: 1px solid #e0e0e0;
 gridline-color: #f0f0f0;
 alternate-background-color: #fafafa;
}

QHeaderView::section {
 background-color: #f5f5f5;
 color: #2c3e50;
 border: none;
 padding: 6px;
}

QTabWidget::pane {
 border: 1px solid #e0e0e0;
 background: #ffffff;
}

QTabBar::tab {
 background: #f5f5f5;
 padding: 8px 12px;
 border: 1px solid #e0e0e0;
 border-bottom: none;
}

QTabBar::tab:selected {
 background: #ffffff;
 border-bottom: 2px solid #0078d7;
}

QComboBox {
 border: 1px solid #777575;
 padding: 4px;
 background: white;
}

QSlider::groove:horizontal {
 height: 5px;
 background: #d0d0d0;
}

QLabel#TableOverLay {
    color: #888888;
    font-size: 14px;
    font-weight: normal;
    background-color: rgba(45, 45, 45, 180);
    border: 2px dashed #555555;
    border-radius: 10px;
    padding: 20px;
}

QSlider::handle:horizontal {
 background: #0078d7;
 width: 12px;
 margin: -4px 0;
 border-radius: 6px;
}

QRadioButton, QCheckBox {
 spacing: 6px;
}

